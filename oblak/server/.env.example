# Copy this file to `.env` and fill in real values.
# SECURITY: secrets must NEVER be hard-coded in source (req. ZR-K2).
# The .env file must NOT be committed (see .gitignore).

# Strong random secret used to sign JWT access tokens (HMAC-SHA256).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
OBLAK_JWT_SECRET=change-me-to-a-long-random-value

# Access token lifetime in minutes (short-lived; req. ZR-A3).
OBLAK_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database URL (default: local SQLite file).
OBLAK_DATABASE_URL=sqlite:///./oblak.db

# Where uploaded code packages are stored (Member 2 replaces with real storage).
OBLAK_STORAGE_DIR=./_storage

# Append-only audit log location (req. ZR-L4).
OBLAK_AUDIT_LOG_PATH=./logs/audit.log

# Max accepted upload size in bytes (req. ZR-V2). Default 5 MiB.
OBLAK_MAX_UPLOAD_BYTES=5242880

# Login rate limiting (req. ZR-A5): max failed attempts per window, window seconds.
OBLAK_LOGIN_MAX_ATTEMPTS=5
OBLAK_LOGIN_WINDOW_SECONDS=300
